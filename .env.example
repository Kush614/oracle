# Oracle — environment
# Everything works with defaults and in-process fallbacks. Set a key to enable
# the live integration for that sponsor.

# Oracle's public URL (used in cited.md attestation block)
ORACLE_PUBLIC_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Redis — hot operational bus (market state, evidence stream, odds timeseries)
# Leave blank to use the in-process fallback.
REDIS_URL=

# ---------------------------------------------------------------------------
# Ghost.build — warm Postgres store.
#   1. curl -fsSL https://install.ghost.build/ | sh
#   2. ghost login            # GitHub OAuth
#   3. ghost create oracle    # creates a Postgres instance
#   4. ghost connect oracle   # prints the connection string — paste below
#
# GHOST_DATABASE_URL is the only required env var for live warm-store mode.
# GHOST_API_KEY enables programmatic DB management (create/fork/list) from
# scripts; not needed by the running app.
GHOST_DATABASE_URL=
GHOST_API_KEY=

# ---------------------------------------------------------------------------
# Nexla — evidence normalization pipeline
NEXLA_API_URL=
NEXLA_API_KEY=

# ---------------------------------------------------------------------------
# TinyFish — evidence browser (Agent API + Fetch API).
# Only TINYFISH_API_KEY is required; hosts default to the public endpoints.
TINYFISH_API_KEY=
TINYFISH_API_URL=https://agent.tinyfish.ai
TINYFISH_FETCH_URL=https://api.fetch.tinyfish.ai
TINYFISH_RUN_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Guild.ai — agent tournament control plane
GUILD_API_URL=
GUILD_API_KEY=
GUILD_WORKSPACE_ID=

# ---------------------------------------------------------------------------
# InsForge — AI reasoning for verdict narratives (spec §8.7).
# Provision a trial project:
#   curl -X POST https://api.insforge.dev/agents/v1/signup \
#     -H 'content-type: application/json' \
#     -d '{"projectName":"oracle"}'
# The response includes accessApiKey + projectUrl. Paste them here.
INSFORGE_PROJECT_URL=
INSFORGE_API_KEY=
INSFORGE_MODEL=openai/gpt-4o-mini
INSFORGE_TIMEOUT_MS=20000

# ---------------------------------------------------------------------------
# Wundergraph — federated GraphQL
WUNDERGRAPH_URL=

# ---------------------------------------------------------------------------
# Chainguard — container attestation
CHAINGUARD_IMAGE=cgr.dev/oracle/resolver:latest
CHAINGUARD_DIGEST=

# ---------------------------------------------------------------------------
# x402 — payment gates (paper credits in demo)
X402_MARKET_CREATE_PRICE=0.10
X402_EVIDENCE_UNLOCK_PRICE=0.05
X402_CHALLENGE_PRICE=0.25

# ---------------------------------------------------------------------------
# Oracle thresholds
ORACLE_RESOLVE_THRESHOLD=0.85
ORACLE_CHALLENGE_THRESHOLD=0.70
ORACLE_NO_CONSENSUS_THRESHOLD=0.60
ORACLE_DEFAULT_DEADLINE_HOURS=4
